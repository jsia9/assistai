generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                String    @id @default(cuid())
  name              String
  plan              String    @default("starter")
  active            Boolean   @default(true)
  monthlyTokenLimit Int       @default(500000)
  systemPrompt      String?   @db.Text
  country           String?   // legacy field — use countryCode
  preferredProvider String?   // "cinetpay" | "paydunya" | "wave"
  // ── Phase 1: Multi-region ──────────────────────────────────────
  region            String    @default("WA")       // "WA" | "MAGHREB" | "HOA"
  countryCode       String    @default("SN")       // ISO 3166-1 alpha-2
  currency          String    @default("XOF")      // "XOF" | "MAD" | "TND" | "ETB"
  defaultLocale     String    @default("fr")       // "fr" | "en" | "ar"
  timezone          String    @default("Africa/Dakar")
  // ── Plan lifecycle ─────────────────────────────────────────────
  /// Set when tenant is first activated on a paid or trial plan.
  /// Used to enforce Découverte max-3-month and trial 72h windows.
  planStartedAt     DateTime?
  /// Set when plan = "trial". Chat is blocked after this timestamp.
  trialEndsAt       DateTime?
  createdAt         DateTime  @default(now())
  users             User[]
  messages          Message[]
  payments          Payment[]
  projects          Project[]
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String?
  role          String         @default("user")   // "user" | "admin" | "superadmin"
  active        Boolean        @default(true)
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  conversations Conversation[]
  projects      Project[]
  createdAt     DateTime       @default(now())
  lastActiveAt  DateTime       @default(now())
}

model Project {
  id            String            @id @default(cuid())
  name          String
  instructions  String?           @db.Text   // custom system prompt for this project
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  documents     ProjectDocument[]
  conversations Conversation[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ProjectDocument {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  content       String   @db.Text
  mimeType      String?
  sizeBytes     Int      @default(0)
  tokenEstimate Int      @default(0)  // rough estimate: content.length / 4
  createdAt     DateTime @default(now())
}

model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("Nouvelle conversation")
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id               String       @id @default(cuid())
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id])
  tenantId         String
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  role             String
  content          String       @db.Text
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  /// Tokens réels retournés par l'API Anthropic avant application du coefficient
  realTokensUsed   Int?
  /// Coefficient de facturation appliqué (Haiku=0.3, Sonnet=1.0, Opus=5.0)
  modelCoefficient Float?
  createdAt        DateTime     @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  amountFcfa  Int      @default(0)          // montant en FCFA (source de vérité)
  type        String   @default("subscription") // "subscription" | "topup"
  tokensAdded Int      @default(0)          // tokens ajoutés (recharge uniquement)
  method      String   @default("cash")
  reference   String?
  period      String                        // "2026-05"
  notes       String?
  paidAt      DateTime @default(now())
  createdById String?
  // Champs legacy (anciens paiements en USD)
  amount      Float    @default(0)
  currency    String   @default("XOF")
  transactionId     String?   @unique // ARIA-{tenantId}-{ts}-{uuid}, null for old cash payments
  providerName      String    @default("cash") // "cash" | "cinetpay"
  providerRef       String?   // provider's own token/ref
  operator          String?   // "OM" | "WAVE" | "MTN" | "MOOV" | "VISA" etc.
  status            String    @default("PAID") // "PENDING" | "PAID" | "FAILED" | "CANCELLED"
  initiatedAt       DateTime  @default(now())
  failureReason     String?
  rawProviderPayload Json?
}

/// Append-only security audit log. Never UPDATE or DELETE.
/// Created in response to security audit (May 2026, ST-018/019).
model AuditLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  // Who did it. actorId may be null for failed login attempts.
  actorId     String?
  actorEmail  String?
  actorRole   String?
  actorTenant String?
  // What happened. action is a stable enum-like string, e.g. "login.success",
  // "login.failure", "user.suspend", "user.password_reset", "payment.create",
  // "tenant.update", "project.delete".
  action      String
  // What it was done to. Stored loosely so we can log across resource types.
  targetType  String?  // "User" | "Tenant" | "Payment" | "Project" | "Conversation" | null
  targetId    String?
  // Context that helps incident response. Keep this JSON small.
  metadata    Json?
  // Where it came from.
  ip          String?
  userAgent   String?

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
}
